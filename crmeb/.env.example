APP_DEBUG = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = mysql
HOSTPORT = 3306
USERNAME = root
PASSWORD = <change-me>
DATABASE = crmeb
PREFIX = eb_
CHARSET = utf8mb4
DEBUG = true

[LANG]
default_lang = zh-cn

[CACHE]
DRIVER = redis
CACHE_PREFIX = cache_<random-hex>:
CACHE_TAG_PREFIX = cache_tag_<random-hex>:

[REDIS]
REDIS_HOSTNAME = redis
PORT = 6379
REDIS_PASSWORD = <change-me>
SELECT = 0

[QUEUE]
QUEUE_NAME = <random-hex>

# 可选：珍珠 demo 的 Unsplash 拉图 key
# [UNSPLASH]
# access_key = <your-unsplash-access-key>
